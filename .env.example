# Firebase Admin SDK (server-side only — never expose these)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Gemini API — used for question generation, interview conversation, and feedback
# Free tier: 60 requests/min  https://ai.google.dev
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# Voice: uses browser-native Web Speech API (free, no keys needed)
# Works in Chrome, Edge, and Safari 15+
